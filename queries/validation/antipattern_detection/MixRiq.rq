prefix gist: <https://w3id.org/semanticarts/ns/ontology/gist/>
prefix gistx: <https://w3id.org/semanticarts/ns/taxonomy/gist/>
prefix ontouml: <https://w3id.org/ontouml#>
prefix owl: <http://www.w3.org/2002/07/owl#>
prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix skos: <http://www.w3.org/2004/02/skos/core#>
prefix xml: <http://www.w3.org/XML/1998/namespace>
prefix xsd: <http://www.w3.org/2001/XMLSchema#>

# Mixin With Same Rigidity

# A class stereotyped as Mixin specialized only by other classes that have the same rigidity property, i.e., are all rigid or all anti-rigid.
# 


SELECT DISTINCT ?invalid ?error_msg
WHERE {

gufo:Mixin ^rdfs:subClassOf* ?subclass

FILTER (?class2 != ?class3)

BIND("This class is an instance of the DecInt anti-pattern, see more at: https://ontouml.readthedocs.io/en/latest/anti-patterns/DecInt/index.html" AS ?error_msg)

}

