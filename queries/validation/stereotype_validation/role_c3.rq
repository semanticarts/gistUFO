prefix gist: <https://w3id.org/semanticarts/ns/ontology/gist/>
prefix owl: <http://www.w3.org/2002/07/owl#>
prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix gufo: <http://purl.org/nemo/gufo#>
 
# Role Constraint 3

# A «Role» cannot be a super-type of a rigid type.

SELECT ?invalid_class ?rigid_subclass ?error_msg
WHERE {

    ?rigid_type rdfs:subClassOf gufo:RigidType .

    ?rigid_class a ?rigid_type .

    ?invalid_class a gufo:Role ;
        ^rdfs:subClassOf+ ?rigid_class .

    BIND("A Role cannot be a superclass of a rigid class." AS ?error_msg)

}
