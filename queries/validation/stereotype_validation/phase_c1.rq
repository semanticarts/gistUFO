prefix gist: <https://w3id.org/semanticarts/ns/ontology/gist/>
prefix gistx: <https://w3id.org/semanticarts/ns/taxonomy/gist/>
prefix ontouml: <https://w3id.org/ontouml#>
prefix owl: <http://www.w3.org/2002/07/owl#>
prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix skos: <http://www.w3.org/2004/02/skos/core#>
prefix xml: <http://www.w3.org/XML/1998/namespace>
prefix xsd: <http://www.w3.org/2001/XMLSchema#>
prefix gufo: <http://purl.org/nemo/gufo#>
 
# Phase Constraint 1 

# A «Phase» must always have exactly one identity provider as an ancestor (a direct or indirect super-type).

SELECT ?invalid ?identity_provider ?identity_provider_2 ?error_msg
WHERE {
    
    ?invalid a gufo:Phase . 

    ?identity_provider a gufo:Kind .
    
    ?identity_provider_2 a gufo:Kind .
       
    ?invalid rdfs:subClassOf+ ?identity_provider, ?identity_provider_2 .

    FILTER (?identity_provider != ?identity_provider_2 || !BOUND(?identity_provider)) 

    BIND("A Phase must always have exactly one identity provider as an ancestor." AS ?error_msg)
}