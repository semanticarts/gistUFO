prefix gist: <https://w3id.org/semanticarts/ns/ontology/gist/>
prefix owl: <http://www.w3.org/2002/07/owl#>
prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix gufo: <http://purl.org/nemo/gufo#>
 
# Role Constraint 2

# Every «Role» must be connected, directly or indirectly, to a «Mediation» relation, since it is a relationally dependent construct.

SELECT ?invalid_class ?error_msg
WHERE {

    ?invalid_class a gufo:Role . 
        
    FILTER NOT EXISTS {?invalid_class rdfs:subClassOf [ a owl:Restriction ; owl:onProperty ?participationProperty ; owl:someValuesFrom [] ] . ?participationProperty rdfs:subPropertyOf* gist:hasParticipant . }

    BIND("Every Role must be connected, directly or indirectly, to a Mediation relation, since it is a relationally dependent construct." AS ?error_msg)

}
