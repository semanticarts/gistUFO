prefix gist: <https://w3id.org/semanticarts/ns/ontology/gist/>
prefix gistx: <https://w3id.org/semanticarts/ns/taxonomy/gist/>
prefix ontouml: <https://w3id.org/ontouml#>
prefix owl: <http://www.w3.org/2002/07/owl#>
prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix skos: <http://www.w3.org/2004/02/skos/core#>
prefix xml: <http://www.w3.org/XML/1998/namespace>
prefix xsd: <http://www.w3.org/2001/XMLSchema#>

# Infer classes into the Subkind stereotype.

CONSTRUCT {

    ?class_iri ontouml:stereotype ontouml:subkind .

}
WHERE {

    ?class_iri
        gist:isCategorizedBy
            gistx:_Rigidity_rigid ,
            gistx:_IdentityProvision_does_not_provide_identity ,
            gistx:_IdentityPrincipleType_simple ,
            gistx:_Dependency_optional ;
        .

}
