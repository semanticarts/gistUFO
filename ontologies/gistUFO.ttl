	.

gist:Event
	a gufo:EndurantType ;
	rdfs:subClassOf
		gufo:Individual ,
		[
			a owl:Class ;
			owl:unionOf (
				gufo:Aspect
				gufo:Event
			) ;
		]
		;
	gist:ufoMappingNote
		"Originally mapped to gufo:Event. Using union pattern to account for subclasses of gist:Event that are mapped to subclasses of gufo:Aspect."^^xsd:string ,
		"Retaining mapping to gufo:Individual so that gist:Event falls under gufo:Individual when viewing in Protege."^^xsd:string
		;
	.

gist:EventSpecification
	a gufo:Kind ;
	rdfs:subClassOf gufo:Object ;
	.

gist:FormattedContent
	a gufo:Category ;
	rdfs:subClassOf gufo:Object ;
	.

gist:Function
	a gufo:AbstractIndividualType ;
	rdfs:subClassOf gufo:AbstractIndividual ;
	.

gist:GeneralMediaType
	a gufo:AbstractIndividualType ;
	rdfs:subClassOf gufo:QualityValue ;
	.

gist:GeoLocation
	a gufo:Kind ;
	rdfs:subClassOf gufo:Endurant ;
	gist:ufoMappingNote "Originally mapped to gufo:Object. However, there was an error in the formal definition of gist:GeoRoute that generated an inconsistency, so the mapping is generalized to gufo:Endurant for now."^^xsd:string ;
	.

gist:GeoPoint
	a gufo:SubKind ;
	gist:ufoMappingNote "Originally mapped to gufo:Object. However, there was an error in the formal definition of gist:GeoRoute that generated an inconsistency, so this mapping is left out of gistUFO for now."^^xsd:string ;
	.

gist:GeoRegion
	a gufo:SubKind ;
	rdfs:subClassOf [
		a owl:Class ;
		owl:unionOf (
			gufo:FixedCollection
			gufo:ExtrinsicMode
		) ;
	] ;
	gist:ufoMappingNote "Originally mapped to gufo:FixedCollection. Using union pattern to account for instances of gist:GovernedGeoRegion."^^xsd:string ;
	.

gist:GeoRoute
	a gufo:Type ;
	gist:ufoMappingNote "Removing the mapping to gufo:Collection, as all the members of a geo route are likely abstract. Compare with gist:UnitGroup."^^xsd:string ;
	.

gist:GeoVolume
	a gufo:SubKind ;
	rdfs:subClassOf gufo:FixedCollection ;
	.

gist:GovernedGeoRegion
	a gufo:Role ;
	rdfs:subClassOf gufo:ExtrinsicMode ;
	.

gist:GovernmentOrganization
	a gufo:SubKind ;
	rdfs:subClassOf gufo:FunctionalComplex ;
	.

gist:HistoricalEvent
	a gufo:EventType ;
	rdfs:subClassOf gufo:Event ;
	.

gist:ID
	a gufo:Kind ;
	rdfs:subClassOf gufo:ExtrinsicMode ;
	.

gist:IntellectualProperty
	a gufo:Category ;
	rdfs:subClassOf gufo:Object ;
	.

gist:Intention
	a gufo:Type ;
	rdfs:subClassOf
		gufo:Individual ,
		[
			a owl:Class ;
			owl:unionOf (
				gufo:AbstractIndividual
				gufo:Endurant
			) ;
		]
		;
	gist:ufoMappingNote
		"Mapped to the union of gufo:AbstractIndividual and gufo:Endurant, as instances of gist:Function are likely to be abstract and other subclasses of gist:Intention fall under gufo:Endurant. This mapping accounts for all cases while remaining as specific as possible."^^xsd:string ,
		"Mapping to gufo:Individual is retained so that gist:Intention falls under gufo:Individual when viewing in Protege."^^xsd:string
		;
	.

