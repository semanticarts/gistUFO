# imports: http://purl.org/nemo/gufo#/1.0.0
# imports: https://w3id.org/semanticarts/ontology/gistCore14.0.0

@prefix ex: <https://example.org/> .
@prefix gist: <https://w3id.org/semanticarts/ns/ontology/gist/> .
@prefix gistd: <https://w3id.org/semanticarts/ns/data/gist/> .
@prefix gistx: <https://w3id.org/semanticarts/ns/taxonomy/gist/> .
@prefix gufo: <http://purl.org/nemo/gufo#> .
@prefix ontouml: <https://w3id.org/ontouml#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/semanticarts/ontology/gistUFO>
	a owl:Ontology ;
	owl:imports
		<http://purl.org/nemo/gufo#/1.0.0> ,
		<https://w3id.org/semanticarts/ontology/gistCore14.0.0>
		;
	owl:versionIRI <https://w3id.org/semanticarts/ontology/gistUFOX.x.x> ;
	skos:definition """gistUFO is the union of gist, gUFO, and a mapping between them. There are three components to the mapping:
	
	(1) A mapping from gist classes to gUFO classes on the gufo:Individual side of the hierarchy using rdfs:subClassOf;
	(2) A mapping from gist classes to gUFO classes on the gufo:Type side of the hierarchy using rdf:type;
	(3) A mapping from gUFO classes to gUFO classes on the gufo:Type side of the hierarchy using rdf:type.
	
	An initial version of each of these mappings is stored in our GitHub respository. The version of the mapping contained in gistUFO uses these mappings as a starting place but makes amendments to preserve logical consistency.
	"""^^xsd:string ;
	skos:prefLabel "gistUFO"^^xsd:string ;
	gist:license "https://creativecommons.org/licenses/by/4.0/"^^xsd:anyURI ;
	.

gufo:AbstractIndividual
	a gufo:AbstractIndividualType ;
	.

gufo:Aspect
	a gufo:Category ;
	.

gufo:Collection
	a gufo:Category ;
	.

gufo:ConcreteIndividual
	a gufo:ConcreteIndividualType ;
	.

