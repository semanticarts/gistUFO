# imports: http://purl.org/nemo/gufo#/1.0.0
# imports: https://w3id.org/semanticarts/ontology/gistCore14.0.0

@prefix gist: <https://w3id.org/semanticarts/ns/ontology/gist/> .
@prefix gistx: <https://w3id.org/semanticarts/ns/taxonomy/gist/> .
@prefix gufo: <http://purl.org/nemo/gufo#> .
@prefix ontouml: <https://w3id.org/ontouml#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/semanticarts/ontology/gistUFO>
	a owl:Ontology ;
	owl:imports
		<http://purl.org/nemo/gufo#/1.0.0> ,
		<https://w3id.org/semanticarts/ontology/gistCore14.0.0>
		;
	owl:versionIRI <https://w3id.org/semanticarts/ontology/gistUFOX.x.x> ;
	skos:definition "An alignment of gist with UFO."^^xsd:string ;
	skos:prefLabel "gistUFO"^^xsd:string ;
	gist:license "https://creativecommons.org/licenses/by/4.0/"^^xsd:anyURI ;
	.

gist:Aspect
	rdfs:subClassOf gufo:AbstractIndividual ;
	.

gist:Category
	rdfs:subClassOf gufo:Type ;
	.

gist:Component
	rdfs:subClassOf gufo:Individual ;
	.

gist:Composite
	rdfs:subClassOf gufo:Collection ;
	.

gist:Content
	rdfs:subClassOf gufo:AbstractIndividual ;
	.

gist:Event
	rdfs:subClassOf gufo:Event ;
	.

gist:IntellectualProperty
	rdfs:subClassOf gufo:AbstractIndividual ;
	.

gist:Intention
	rdfs:subClassOf gufo:IntrinsicAspect ;
	.

gist:Language
	rdfs:subClassOf gufo:AbstractIndividual ;
	.

gist:Magnitude
	rdfs:subClassOf gufo:Aspect ;
	.

gist:Organization
	rdfs:subClassOf gufo:Collection ;
	.

gist:PhysicalIdentifiableItem
	rdfs:subClassOf gufo:Object ;
	.

gist:PhysicalSubstance
	rdfs:subClassOf gufo:Quantity ;
	.

gist:SchemaMetaData
	rdfs:subClassOf gufo:AbstractIndividual ;
	.

gist:Template
	rdfs:subClassOf gufo:AbstractIndividual ;
	.

gist:TemporalRelation
	rdfs:subClassOf gufo:Relator ;
	.

gist:UnitOfMeasure
	rdfs:subClassOf gufo:AbstractIndividual ;
	.

