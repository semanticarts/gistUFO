	a gufo:Category ;
	.

gist:Account
	a gufo:SubKind ;
	rdfs:subClassOf gufo:Relator ;
	.

gist:Address
	a gufo:Category ;
	rdfs:subClassOf gufo:ExtrinsicMode ;
	.

gist:AddressUsageType
	a gufo:AbstractIndividualType ;
	rdfs:subClassOf gufo:QualityValue ;
	.

gist:Agreement
	a gufo:Kind ;
	rdfs:subClassOf gufo:Relator ;
	.

gist:Aspect
	a gufo:AbstractIndividualType ;
	rdfs:subClassOf gufo:AbstractIndividual ;
	.

gist:Assignment
	a gufo:SituationType ;
	rdfs:subClassOf gufo:TemporaryRelationshipSituation ;
	.

gist:Behavior
	a gufo:AbstractIndividualType ;
	rdfs:subClassOf gufo:QualityValue ;
	.

gist:Building
	a gufo:Kind ;
	rdfs:subClassOf gufo:Object ;
	.

gist:BundledCatalogItem
	a gufo:EndurantType ;
	rdfs:subClassOf gufo:Object ;
	.

gist:CatalogItem
	a gufo:Category ;
	rdfs:subClassOf gufo:Object ;
	.

gist:Category
	a gufo:AbstractIndividualType ;
	rdfs:subClassOf gufo:QualityValue ;
	.

gist:Collection
	a gufo:Type ;
	rdfs:subClassOf gufo:Individual ;
	gist:ufoMappingNote "In the initial mapping gist:Collection was a subclass of gufo:Object. However, some subclasses of gist:Collection have abstract instances, so we are generalizing this mapping to gufo:Individual."^^xsd:string ;
	.

gist:Commitment
	a gufo:Kind ;
	rdfs:subClassOf gufo:Relator ;
	.

gist:Component
	a gufo:Category ;
	rdfs:subClassOf gufo:Individual ;
	.

gist:Composite
	a gufo:Category ;
	rdfs:subClassOf gufo:Individual ;
	.

gist:ContemporaryEvent
	a gufo:EventType ;
	rdfs:subClassOf gufo:Event ;
	.

gist:Content
	a gufo:Category ;
	rdfs:subClassOf
		gufo:Endurant ,
		[
			a owl:Class ;
			owl:unionOf (
				gufo:ExtrinsicMode
				gufo:Object
			) ;
		]
		;
	gist:ufoMappingNote
		"Originally mapped to gufo:Object, but employing union pattern to account for gist:ID, gist:Address, and gist:Message, which are subclasses of gufo:ExtrinsicMode."^^xsd:string ,
		"Retaining mapping to gufo:Endurant so that gist:Content falls under gufo:Endurant when viewing in Protege."^^xsd:string
		;
	.

gist:ContentExpression
	a gufo:Category ;
	rdfs:subClassOf [
		a owl:Class ;
		owl:unionOf (
			gufo:ExtrinsicMode
			gufo:Object
		) ;
	] ;
	gist:ufoMappingNote "Originally mapped to gufo:Object, but employing union pattern to account for gist:Message, which is a subclass of gufo:ExtrinsicMode."^^xsd:string ;
	.

gist:ContingentEvent
	a gufo:Kind ;
	rdfs:subClassOf gufo:ExtrinsicMode ;
	.

gist:ContingentObligation
	a gufo:Phase ;
	rdfs:subClassOf gufo:Relator ;
	.

gist:Contract
	a gufo:SubKind ;
	rdfs:subClassOf gufo:Relator ;
	.

gist:ContractTerm
	a gufo:Role ;
	rdfs:subClassOf gufo:Object ;
	.

gist:ControlledVocabulary
	a gufo:EndurantType ;
	rdfs:subClassOf gufo:VariableCollection ;
	.

gist:CountryGeoRegion
	a gufo:Role ;
	rdfs:subClassOf gufo:ExtrinsicMode ;
	.

gist:CountryGovernment
	a gufo:SubKind ;
	rdfs:subClassOf gufo:FunctionalComplex ;
	.

gist:DegreeOfCommitment
	a gufo:AbstractIndividualType ;
