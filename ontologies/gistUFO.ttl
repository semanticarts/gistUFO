	.

gist:ufoMappingNote
	a owl:AnnotationProperty ;
	rdfs:subPropertyOf skos:editorialNote ;
	skos:definition "Information regarding the mapping between gist and UFO ontologies, how a resource was mapped, or clarifications on the mapping."^^xsd:string ;
	skos:prefLabel "UFO mapping note"^^xsd:string ;
	.

